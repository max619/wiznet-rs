{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "preLaunchTask": "cargo build example: spi_dma_loopback",
            "type": "probe-rs-debug",
            "request": "launch",
            "name": "Debug example: spi_dma_loopback",
            "cwd": "${workspaceFolder}",
            "connectUnderReset": true,
            "chip": "STM32F103C8Tx",
            "flashingConfig": {
                "flashingEnabled": true,
                "haltAfterReset": true
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "${workspaceFolder}/target/thumbv7m-none-eabi/debug/examples/spi_dma_loopback"
                }
            ]
        },
        {
            "preLaunchTask": "rust: cargo build",
            "type": "probe-rs-debug",
            "request": "launch",
            "name": "probe-rs Test",
            "cwd": "${workspaceFolder}",
            "connectUnderReset": false,
            "chip": "STM32F103C8Tx",
            "flashingConfig": {
                "flashingEnabled": true,
                "haltAfterReset": true
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "${workspaceFolder}/target/thumbv7m-none-eabi/debug/stm32_rust"
                }
            ]
        }
    ]
}